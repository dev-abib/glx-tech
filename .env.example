# ══════════════════════════════════════════════
# Environment Configuration
# ══════════════════════════════════════════════
#
# This file was auto-generated by:
#   npm run generate:env-example
#
# Copy this file to .env and fill in your values.
#
# Note: vars marked with ⚠ are required — the server won't start without them.


# ──────────────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────────────

# Port the Express server listens on
PORT=5000

# Runtime environment (development | production | test)
NODE_ENV=development

# API route prefix
API_VERSION=/api/v1

# ──────────────────────────────────────────────
# Database — PostgreSQL
# ──────────────────────────────────────────────
# ⚠ Required: DATABASE_URL

# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Direct connection string for Prisma migrations (not pooled)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ──────────────────────────────────────────────
# JWT — User tokens (login / registration)
# ──────────────────────────────────────────────
# ⚠ Required: JWT_ACCESS_SECRET, JWT_REFRESH_SECRET

# Secret for signing user access tokens (required)
JWT_ACCESS_SECRET=change-me-user-access-secret

JWT_ACCESS_EXPIRES_IN=15m

# Secret for signing user refresh tokens (required)
JWT_REFRESH_SECRET=change-me-user-refresh-secret

JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# JWT — Admin / Super Admin tokens
# ──────────────────────────────────────────────
# ⚠ Required: JWT_ADMIN_SECRET, JWT_ADMIN_REFRESH_SECRET

# Secret for signing admin access tokens (required)
JWT_ADMIN_SECRET=change-me-admin-access-secret

JWT_ADMIN_EXPIRES_IN=15m

# Secret for signing admin refresh tokens (required)
JWT_ADMIN_REFRESH_SECRET=change-me-admin-refresh-secret

JWT_ADMIN_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# JWT — Password reset token
# ──────────────────────────────────────────────
# ⚠ Required: JWT_RESET_SECRET

# Secret for signing password-reset tokens (required)
JWT_RESET_SECRET=change-me-reset-secret

JWT_RESET_EXPIRES_IN=15m

# ──────────────────────────────────────────────
# SMTP — Email
# ──────────────────────────────────────────────
# ⚠ Required: MAIL_HOST, MAIL_PORT, MAIL_USERNAME, MAIL_PASSWORD, MAIL_FROM_NAME, MAIL_FROM_ADDRESS

# SMTP server hostname (required)
MAIL_HOST=smtp.gmail.com

# SMTP server port (required)
MAIL_PORT=465

# SMTP username (required)
MAIL_USERNAME=you@gmail.com

# SMTP password or app password (required)
MAIL_PASSWORD=your-app-password

# Sender display name (required)
MAIL_FROM_NAME=YourAppName

# Sender email address (required)
MAIL_FROM_ADDRESS=you@gmail.com

# Mail driver (used by underlying mail library)
MAIL_MAILER=smtp

# Encryption protocol for SMTP
MAIL_ENCRYPTION=SSL

# Site owner email for admin notifications
SITE_OWNER_MAIL=admin@yourapp.com

# ──────────────────────────────────────────────
# Cloudinary
# ──────────────────────────────────────────────
# ⚠ Required: CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET

# Cloudinary cloud name (required)
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API key (required)
CLOUDINARY_API_KEY=123456789012345

# Cloudinary API secret (required)
CLOUDINARY_API_SECRET=abc123def456

# Base folder prefix in Cloudinary for app uploads
CLOUDINARY_BASE_FOLDER=my-app

# ──────────────────────────────────────────────
# Site
# ──────────────────────────────────────────────

# Application name used in email templates
SITE_NAME=YourAppName

# Application website URL used in email footers
SITE_URL=https://yourapp.com

# Application root URL used in email CTA buttons
APP_URL=https://api.yourapp.com

# Frontend URL used for Stripe checkout redirects and link generation
FRONTEND_URL=https://yourapp.com

# ══════════════════════════════════════════════
