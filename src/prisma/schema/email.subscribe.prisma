enum CampaignStatus {
  draft
  sending
  sent
}

model EmailSubscribe {
  id               String   @id() @default(uuid())
  email            String   @unique()
  unsubscribeToken String   @unique @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())
}

model Campaign {
  id        String          @id @default(uuid())
  subject   String
  heading   String
  bodyHtml  String
  ctaText   String?
  ctaLink   String?
  status    CampaignStatus  @default(draft)
  createdAt DateTime        @default(now())
  sentAt    DateTime?

  @@map("campaigns")
}
