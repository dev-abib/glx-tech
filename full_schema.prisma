model AboutUs {
  id             String   @id @default(uuid())
  title          String
  description    String
  image1         String?
  image1PublicId String?  @map("image1_public_id")
  image2         String?
  image2PublicId String?  @map("image2_public_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("about_us")
}
enum STATUS {
  pending
  confirmed
  cancelled
  completed
}

model Appointment {
  id          String  @id @default(cuid())
  listingId   String
  listing     Listing @relation(fields: [listingId], references: [id])
  buyerId     String
  sellerId    String
  bookingDate String
  bookingTime String
  status      STATUS  @default(pending)

  // Prevent exact duplicate appointments for the same listing + date + time + status combo.
  // The primary guard against double-booking is the service-level check
  // (no two non-cancelled appointments for the same listing+date+time).
  @@unique([listingId, bookingDate, bookingTime, status])
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model ContactInquiry {
  id           String    @id @default(uuid())
  name         String
  email        String
  phone        String?
  subject      String?
  message      String
  isRead       Boolean   @default(false) @map("is_read")
  isReplied    Boolean   @default(false) @map("is_replied")
  replyMessage String?   @map("reply_message")
  repliedAt    DateTime? @map("replied_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("contact_inquiries")
}
enum DonationStatus {
  pending
  completed
  failed
}

/// Donation records created via Stripe payment links / checkout sessions.
model Donation {
  id                  String         @id @default(uuid())
  amount              Float?
  currency            String         @default("usd")
  stripeSessionId     String?        @unique
  stripePaymentId     String?
  stripePaymentLinkId String?
  customerEmail       String?
  customerName        String?
  message             String?
  status              DonationStatus @default(pending)
  metadata            Json?
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@map("donations")
}
enum CampaignStatus {
  draft
  sending
  sent
}

model EmailSubscribe {
  id               String   @id() @default(uuid())
  email            String   @unique()
  unsubscribeToken String   @unique @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())
}

model Campaign {
  id        String         @id @default(uuid())
  subject   String
  heading   String
  bodyHtml  String
  ctaText   String?
  ctaLink   String?
  status    CampaignStatus @default(draft)
  createdAt DateTime       @default(now())
  sentAt    DateTime?

  @@map("campaigns")
}
model Service {
  id           String  @id @default(uuid())
  name         String?
  description  String?
  icon         String?
  iconPublicId String

  heroId   String?
  hero     Hero?     @relation(fields: [heroId], references: [id])
  listings Listing[]
}

model Hero {
  id              String    @id @default(uuid())
  title           String?
  sub_title       String?
  highlighted_txt String?
  services        Service[]
}
model UserReview {
  id        String   @id() @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  rating    Float
  review    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Listing {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  title             String
  slug              String        @unique()
  serviceId         String
  service           Service       @relation(fields: [serviceId], references: [id])
  description       String
  address           String
  media             Json
  days              String[]
  weekend           String[]
  timeSlot          String[]
  basePrice         String
  hourlyPrice       String
  dailyPrice        String
  estimatedDuration String
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  userReview        UserReview[]
  latitude          Float
  longitude         Float
  isAvailable       Boolean       @default(true)
  bookings          Appointment[]
}
model Review {
  id              String         @id() @default(uuid())
  name            String
  position        String
  reviewDate      String
  picture         String
  picturePublicId String
  review          String
  ratingCount     String
  sectionId       String?
  ReviewSection   ReviewSection? @relation(fields: [sectionId], references: [id])
}

model ReviewSection {
  id       String   @id() @default(uuid())
  title    String
  subTitle String
  reviews  Review[]
}
model Social {
  id           String @id @default(uuid())
  icon         String
  iconPublicId String
  socialLink   String
}

model SiteSettings {
  id        String  @id @default(uuid())
  title     String?
  subTitle  String?
  footerTxt String?
  siteLink  String?
  location  String?
  phone     String?
  email     String?
}
// ── Subscription Plan ─────────────────────────────────────────────────────
// CRUD-driven subscription tiers with Stripe integration

/// A subscription tier (e.g. "Starter", "Professional") created via admin panel.
/// Each plan can have multiple features toggled on/off.
model SubscriptionPlan {
  id                  String          @id @default(uuid()) @map("id")
  name                String          @map("name")
  slug                String          @unique @map("slug")
  description         String?         @map("description")
  priceMonthly        Int              @map("priceMonthly")
  priceAnnual         Int              @map("priceAnnual")
  stripePriceIdMonthly  String?       @map("stripe_price_id_monthly")
  stripePriceIdAnnual   String?       @map("stripe_price_id_annual")
  maxActiveListings   Int             @default(0)  @map("maxActiveListings")
  platformFeePercent  Decimal         @default(0)  @map("platformFeePercent")
  isActive            Boolean         @default(true)  @map("isActive")
  isPublic            Boolean         @default(true)  @map("isPublic")
  displayOrder        Int             @default(0)  @map("displayOrder")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  features            PlanFeature[]
  users               User[]

  @@map("subscription_plans")
}

/// Feature toggles per plan. Allows adding new features without a migration.
model PlanFeature {
  id      String  @id @default(uuid()) @map("id")
  planId  String  @map("plan_id")
  plan    SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  key     String  @map("key")
  enabled Boolean @default(false) @map("enabled")

  @@unique([planId, key])
  @@map("plan_features")
}

/// Master list of all possible features. Used to render the pricing table
/// and for the admin UI to know what toggles to show.
model FeatureDefinition {
  id           Int      @id @default(autoincrement()) @map("id")
  key          String   @unique @map("key")
  label        String   @map("label")
  description  String?  @map("description")
  displayOrder Int      @default(0)  @map("displayOrder")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("feature_definitions")
}
enum Role {
  user
  seller
  admin
  super_admin
}

enum Provider {
  local
  google
}

enum Insurance {
  yes
  no
  not_applicable
}

model SellerInfo {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  storeName       String
  servicesId      String[]
  insuranceStatus Insurance
  socialLInk      String
  businessNumber  String
  businessEmail   String
  streetAddress   String
  city            String
  state           String
  zipCode         String
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
}

model User {
  id              String       @id @default(uuid())
  name            String
  email           String       @unique
  password        String
  role            Role         @default(user)
  avatar          String?
  avatarPublicId  String?
  phone           String?
  isEmailVerified Boolean      @default(false) @map("is_email_verified")
  otp             String?
  otpExpiresAt    DateTime?
  otpAttempts     Int?         @default(0)
  isActive        Boolean      @default(true)  @map("isActive")
  isPaid          Boolean      @default(false)
  isResetRequest  Boolean      @default(false)
  blockedUntil    DateTime?
  address         String?
  refreshToken    String?      @map("refresh_token")
  accessToken     String?      @map("accessToken")
  resetToken      String?      @map("resetToken")
  lastLoginAt     DateTime?    @map("last_login_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  subscriptionPlanId String?          @map("subscription_plan_id")
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  subscriptionStatus String?           @map("subscription_status")  // active, past_due, canceled, etc.
  stripeCustomerId   String?           @map("stripe_customer_id")
  stripeSubscriptionId String?         @map("stripe_subscription_id")
  currentPeriodEnd   DateTime?         @map("current_period_end")
  listings           Listing[]
  userReview         UserReview[]
  isSeller           Boolean           @default(false)
  sellerInfo         SellerInfo?

  @@map("users")
}
